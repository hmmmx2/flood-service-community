# Copy this file to .env and fill in real values
# Never commit .env to git
# Service: flood-service-community — Port 4001 (local) / Railway injects PORT

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development
# Railway: set NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local Docker:  jdbc:postgresql://localhost:5433/flood_community?user=flood&password=flood
# Neon (cloud):  jdbc:postgresql://HOST/DBNAME?sslmode=require&user=USER&password=PASS
DATABASE_URL=jdbc:postgresql://localhost:5433/flood_community?user=flood&password=flood

# ── Railway PostgreSQL note ───────────────────────────────────────────────────
# Railway's PostgreSQL plugin sets DATABASE_URL as "postgresql://..." (no jdbc: prefix).
# Spring Boot requires the jdbc: prefix, so add SPRING_DATASOURCE_URL manually:
#   SPRING_DATASOURCE_URL=jdbc:postgresql://HOST/DBNAME?sslmode=require&user=U&password=P
# SPRING_DATASOURCE_URL overrides DATABASE_URL in application.yml.
SPRING_DATASOURCE_URL=

# Docker Compose DB credentials (only needed when using docker-compose up locally)
DB_USER=flood
DB_PASSWORD=flood

# ── HikariCP pool size ────────────────────────────────────────────────────────
# Neon free tier: 10 connections. Railway PostgreSQL: 100. Hobby default: 5.
HIKARI_MAX_POOL_SIZE=5
# Railway: keep at 5 (safe for Neon free tier and Railway hobby plan)

# ── Hibernate DDL ─────────────────────────────────────────────────────────────
# Railway: set HIBERNATE_DDL_AUTO=validate once schema is stable.
HIBERNATE_DDL_AUTO=update

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker: redis://localhost:6380
# Upstash:      rediss://default:TOKEN@HOST:PORT
# Leave empty to use in-memory cache (no Redis needed for local dev without Docker)
REDIS_URL=redis://localhost:6380
# Railway: use Upstash Redis free tier — set REDIS_URL=rediss://default:TOKEN@HOST:PORT

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_hex_string

# ── Ingest API key ─────────────────────────────────────────────────────────────
# Used by flood-service-crm to POST sensor readings. Change in production.
INGEST_API_KEY=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Railway: set to your actual frontend Railway domains, e.g.:
#   CORS_ALLOWED_ORIGINS=https://flood-community.up.railway.app,https://flood-crm.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave empty in development — emails are logged to console instead
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
DEV_EMAIL_RECIPIENT=

# ── MQTT ──────────────────────────────────────────────────────────────────────
# Set MQTT_ENABLED=true once Mosquitto is running (flood-iot-devices service on Railway)
MQTT_ENABLED=false
# Local:   tcp://localhost:1883
# Railway: tcp://flood-iot-devices.railway.internal:1883  (private networking)
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_USERNAME=flood-service
MQTT_PASSWORD=change_me_strong_password
MQTT_CLIENT_ID=flood-service-community
# Max 2 readings/sec per node (500 ms minimum gap) — raise if needed
MQTT_MIN_INTERVAL_MS=500
